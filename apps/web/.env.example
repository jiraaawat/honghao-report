# Local development (SQLite)
DATABASE_URL="file:./dev.db"
TCGDB_URL=""
# Production (PostgreSQL) — replace with your actual connection string
# DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-change-this-in-production"

# Firebase Auth client config (required for social login)
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""

# Feature flags
NEXT_PUBLIC_ENABLE_SOCIAL_LOGIN="false"
NEXT_PUBLIC_ADS_ENABLED="false"

# Firebase Admin SDK (required for server-side token verification)
# Option A: path to service account JSON file
GOOGLE_APPLICATION_CREDENTIALS="./.firebase/serviceAccountKey.json"
# Option B: inline credentials (use this for Vercel etc.)
# FIREBASE_PROJECT_ID=""
# FIREBASE_CLIENT_EMAIL=""
# FIREBASE_PRIVATE_KEY=""
