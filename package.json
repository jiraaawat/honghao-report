{
  "name": "honghao-report",
  "version": "0.1.0",
  "private": true,
  "description": "Honghao Report - Trading card inventory & profit tracking system",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "db:generate": "pnpm --filter web db:generate",
    "db:migrate": "pnpm --filter web db:migrate",
    "db:studio": "pnpm --filter web db:studio"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.1.0"
  },
  "packageManager": "pnpm@9.0.0"
}
